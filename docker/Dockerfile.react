FROM node:20-alpine

RUN corepack enable && corepack prepare pnpm@latest --activate

WORKDIR /app

# Cache dependency installs
COPY runtime/package.json runtime/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Copy source and config
COPY runtime/tsconfig*.json runtime/vite.config.ts runtime/index.html ./
COPY runtime/tailwind.config.ts runtime/postcss.config.js ./
COPY runtime/src/ src/

EXPOSE 5174

CMD ["pnpm", "dev"]
