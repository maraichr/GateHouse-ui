# GateHouse UI - Docker Compose Configuration
# Copy to .env and adjust as needed

# Go Server
GO_SERVER_PORT=3000
SPEC_FILE=docs/gatehouse-ui-spec-schema.yaml
DATA_FILE=docs/data.json

# React Runtime (Vite)
REACT_PORT=5174

# Flutter Runtime
FLUTTER_PORT=6175

# Inter-service URLs (used inside Docker network)
# These are set automatically by docker-compose.yml — override only if needed
# GO_SERVER_URL=http://go-server:3000
# API_BASE_URL=http://go-server:3000/api/v1
